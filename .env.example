# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Serper API (for Google search enrichment)
SERPER_API_KEY=your-serper-key-here

# Comment generation endpoint (FastAPI comment-api, or legacy n8n webhook)
COMMENT_API_URL=http://127.0.0.1:8000/generate-comment

# Anthropic API (optional in Electron .env if only comment-api needs it; comment-api/.env is primary for the Python service)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Set to true for Phase 5 dry run (generate + log, no LinkedIn submit)
AUTOMATION_DRY_RUN=false
# Set to true to bypass operating-hours checks during development/testing
AUTOMATION_ALWAYS_ON=true

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
